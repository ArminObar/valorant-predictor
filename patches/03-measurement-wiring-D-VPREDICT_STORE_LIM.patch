 # --------------------------------------------------------------------------- raw store
-def load_matches(path: Path = config.MATCHES_JSONL) -> list[Match]:
+def _read_matches(path: Path) -> list[Match]:
+    """Uncapped reader. upsert_matches MUST use this, never load_matches:
